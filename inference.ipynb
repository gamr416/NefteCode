{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Inference Pipeline\n",
    "\n",
    "Загрузка моделей и создание предсказаний для submission"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "import os\n",
    "\n",
    "DATA_PATH = 'data/'\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f\"Device: {device}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load data\n",
    "X_train = np.load(f'{DATA_PATH}/X_train.npy')\n",
    "X_test = np.load(f'{DATA_PATH}/X_test.npy')\n",
    "test_ids = pd.read_csv(f'{DATA_PATH}/test_ids.csv')['scenario_id'].tolist()\n",
    "\n",
    "print(f\"Test samples: {X_test.shape[0]}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Model definition\n",
    "class ImprovedDeepSets(nn.Module):\n",
    "    def __init__(self, input_dim, hidden_dim=64, encode_dim=32, dropout=0.3):\n",
    "        super().__init__()\n",
    "        self.encoder = nn.Sequential(\n",
    "            nn.Linear(input_dim, hidden_dim),\n",
    "            nn.LayerNorm(hidden_dim),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(dropout),\n",
    "            nn.Linear(hidden_dim, hidden_dim),\n",
    "            nn.LayerNorm(hidden_dim),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(dropout),\n",
    "            nn.Linear(hidden_dim, encode_dim)\n",
    "        )\n",
    "        self.predictor = nn.Sequential(\n",
    "            nn.Linear(encode_dim, hidden_dim // 2),\n",
    "            nn.ReLU(),\n",
    "            nn.Dropout(dropout),\n",
    "            nn.Linear(hidden_dim // 2, 1)\n",
    "        )\n",
    "    \n",
    "    def forward(self, x):\n",
    "        encoded = self.encoder(x)\n",
    "        return self.predictor(encoded)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load CV models\n",
    "n_folds = 5\n",
    "models_visc = []\n",
    "models_oxid = []\n",
    "\n",
    "for i in range(n_folds):\n",
    "    # Viscosity\n",
    "    m = ImprovedDeepSets(X_train.shape[1])\n",
    "    m.load_state_dict(torch.load(f'models/cv_ds_visc_fold{i}.pth', weights_only=True))\n",
    "    m.eval()\n",
    "    models_visc.append(m)\n",
    "    \n",
    "    # Oxidation\n",
    "    m = ImprovedDeepSets(X_train.shape[1])\n",
    "    m.load_state_dict(torch.load(f'models/cv_ds_oxid_fold{i}.pth', weights_only=True))\n",
    "    m.eval()\n",
    "    models_oxid.append(m)\n",
    "\n",
    "print(f\"Loaded {n_folds} CV models for each target\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Prediction function\n",
    "def predict_ensemble(models, X):\n",
    "    preds = []\n",
    "    for m in models:\n",
    "        m.eval()\n",
    "        with torch.no_grad():\n",
    "            x = torch.tensor(X, dtype=torch.float32).to(device)\n",
    "            p = m(x).squeeze().cpu().numpy()\n",
    "            preds.append(p)\n",
    "    return np.mean(preds, axis=0)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Make predictions\n",
    "pred_visc = predict_ensemble(models_visc, X_test)\n",
    "pred_oxid = predict_ensemble(models_oxid, X_test)\n",
    "\n",
    "print(f\"Viscosity: mean={pred_visc.mean():.2f}, std={pred_visc.std():.2f}\")\n",
    "print(f\"Oxidation: mean={pred_oxid.mean():.2f}, std={pred_oxid.std():.2f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create submission\n",
    "TARGET_VISC = 'Delta Kin. Viscosity KV100 - relative | - Daimler Oxidation Test (DOT), %'\n",
    "TARGET_OXID = 'Oxidation EOT | DIN 51453 Daimler Oxidation Test (DOT), A/cm'\n",
    "\n",
    "submission = pd.DataFrame({\n",
    "    'scenario_id': test_ids,\n",
    "    TARGET_VISC: pred_visc,\n",
    "    TARGET_OXID: pred_oxid\n",
    "})\n",
    "\n",
    "os.makedirs('submissions', exist_ok=True)\n",
    "submission.to_csv('submissions/predictions.csv', index=False)\n",
    "\n",
    "print(f\"Submission saved: {submission.shape}\")\n",
    "print(submission.head())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Validate submission\n",
    "test_orig = pd.read_csv(f'{DATA_PATH}/daimler_mixtures_test.csv')\n",
    "test_scenarios = set(test_orig['scenario_id'].unique())\n",
    "sub_scenarios = set(submission['scenario_id'].unique())\n",
    "\n",
    "print(\"Validation:\")\n",
    f\"  All scenarios match: {test_scenarios == sub_scenarios}\"\n",
    f\"  No nulls: {submission.isnull().sum().sum() == 0}\"\n",
    f\"  No duplicates: {len(submission) == len(submission.drop_duplicates('scenario_id'))}\""
   ]
  }
 ],
